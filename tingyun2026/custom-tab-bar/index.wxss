.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 8rpx;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
  transition: all 0.2s ease;
  position: relative;
}

.tab-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 2rpx;
}

.tab-text {
  font-size: 20rpx;
  color: #7C8A8C;
  font-weight: 400;
  transition: color 0.2s ease;
}

.tab-text-active {
  color: #C9A962;
  font-weight: 600;
}

/* 山图标 CSS 绘制 */
.mountain-icon {
  width: 44rpx;
  height: 38rpx;
  position: relative;
}

.mountain-peak {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 18rpx solid transparent;
  border-right: 18rpx solid transparent;
  border-bottom: 28rpx solid #7C8A8C;
}

.mountain-base {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 12rpx;
  background: #7C8A8C;
  border-radius: 4rpx 4rpx 0 0;
}

.mountain-active .mountain-peak {
  border-bottom-color: #C9A962;
}

.mountain-active .mountain-base {
  background: #C9A962;
}
