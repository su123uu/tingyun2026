.tab-bar { position: fixed; z-index: 50; right: 0; bottom: 0; left: 0; display: flex; padding: 14rpx 0 calc(18rpx + env(safe-area-inset-bottom)); border-top: 1rpx solid rgba(26,26,26,.06); background: rgba(255,255,255,.96); box-shadow: 0 -6rpx 20rpx rgba(26,26,26,.035); }
.tab-item { display: flex; flex: 1; align-items: center; flex-direction: column; gap: 4rpx; color: #929C96; font-size: 21rpx; }
.active { color: #4F6F52; font-weight: 700; }
.tab-icon { display: flex; width: 42rpx; height: 42rpx; align-items: center; justify-content: center; }
