page {
  min-height: 100%;
  color: #1A1A1A;
  background: #F8F6F1;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

button::after { border: 0; }
.page { min-height: 100vh; padding-bottom: 132rpx; box-sizing: border-box; background: #F8F6F1; }
.title { font-size: 44rpx; font-weight: 700; letter-spacing: 4rpx; }
.subtitle { margin-top: 8rpx; color: #7C8A8C; font-size: 23rpx; letter-spacing: 2rpx; }
.card { border-radius: 22rpx; background: #FFFFFF; box-shadow: 0 8rpx 24rpx rgba(26, 26, 26, .05); }
.primary-button { color: #FFFFFF; background: #4F6F52; font-size: 27rpx; }
.secondary-button { color: #4F6F52; border: 1rpx solid rgba(79, 111, 82, .24); background: #FFFFFF; font-size: 27rpx; }
.section-title { display: block; margin: 34rpx 28rpx 16rpx; font-size: 30rpx; font-weight: 700; letter-spacing: 3rpx; }
.muted { color: #7C8A8C; }
