<view class="page inner">
  <view class="topbar">
    <view class="head" style="padding-top: {{navTop}}px;">
      <view class="nav-row" style="height: {{navHeight}}px;">
        <view class="back" bindtap="goBack"><view class="back-arrow"></view></view>
        <text class="title">确认订单</text>
      </view>
      <text class="subtitle">确认菜品与就餐信息</text>
    </view>
  </view>
  <view class="content">
    <view class="dining card">
      <view class="dining-left">
        <view class="dining-cell"><text>区域</text><strong>{{tableArea || '-'}}</strong></view>
        <view class="dining-cell"><text>桌号</text><strong>{{tableNo}}</strong></view>
        <view class="dining-cell"><text>用餐人数</text><strong>{{session.people_count}} 位</strong></view>
      </view>
      <view class="dining-right">
        <block wx:if="{{effectiveCustomerType === 'member'}}">
          <view class="identity-badge member-badge">
            <view class="badge-icon member-icon">{{identityInitial}}</view>
            <view class="badge-info">
              <text class="badge-tag member-tag">会员</text>
              <text class="badge-level">{{memberLevel || '会员'}}</text>
            </view>
          </view>
        </block>
        <block wx:else>
          <view class="identity-badge guest-badge">
            <view class="badge-icon guest-icon">{{identityInitial}}</view>
            <view class="badge-info">
              <text class="badge-tag guest-tag">访客</text>
              <text class="badge-level">散客</text>
            </view>
          </view>
        </block>
      </view>
    </view>

    <view class="section-head">
      <text class="section-title">菜品明细</text>
      <text class="section-note">{{cartCount}} 件菜品</text>
    </view>
    <view class="card dishes">
      <view wx:for="{{cart.items}}" wx:key="item_id" class="dish-item">
        <image src="{{item.image}}" mode="aspectFill" />
        <view class="dish-copy"><strong>{{item.name}}</strong><text>¥{{item.price}} × {{item.quantity}}</text></view>
        <strong class="dish-price">¥{{item.price * item.quantity}}</strong>
      </view>
      <view class="dish-total">
        <text>总价格</text>
        <view class="dish-total-prices">
          <strong>¥{{cart.regular_total_amount}}</strong>
          <text>会员价 ¥{{cart.member_total_amount}}</text>
        </view>
      </view>
    </view>

    <text class="section-title">订单备注</text>
    <view class="remark-card card">
      <textarea value="{{remark}}" maxlength="200" bindinput="remarkInput" placeholder="填写口味、忌口或其他需求"/>
      <view class="quick-list">
        <button wx:for="{{quickRemarks}}" wx:key="text" class="quick {{item.selected ? 'active' : ''}}" data-index="{{index}}" bindtap="toggleQuick">{{item.text}}</button>
      </view>
    </view>

    <view class="settlement-notice">
      <text>用餐完毕再结算</text>
      <text>祝您用餐愉快</text>
    </view>
  </view>
  <view class="footer">
    <view class="pay-copy">
      <strong>¥{{cart.regular_total_amount}}</strong>
      <text>会员价 ¥{{cart.member_total_amount}}</text>
    </view>
    <button class="pay-button" bindtap="submit">提交菜品，稍后结账</button>
  </view>
</view>
