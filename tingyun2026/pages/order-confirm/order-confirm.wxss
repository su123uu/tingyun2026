.inner { padding-bottom:calc(176rpx + env(safe-area-inset-bottom)); }
.topbar { position:sticky; z-index:20; top:0; border-bottom:1rpx solid rgba(26,26,26,.045); background:rgba(248,246,241,.95); backdrop-filter:blur(24rpx); }
.head { display:flex; flex-direction:column; padding:0 188rpx 18rpx 20rpx; }
.nav-row { display:flex; align-items:center; gap:4rpx; }
.back { display:flex; width:48rpx; height:100%; flex:none; align-items:center; justify-content:center; }
.back-arrow { width:18rpx; height:18rpx; border-bottom:3rpx solid #4A554F; border-left:3rpx solid #4A554F; transform:rotate(45deg); }
.title,.subtitle { display:block; }
.title { font-size:40rpx; letter-spacing:4rpx; }
.subtitle { margin:12rpx 0 0 8rpx; }
.content { padding:0 28rpx; }
.dining { display:flex; align-items:center; justify-content:space-between; margin-top:24rpx; padding:28rpx; }
.dining-left { flex: 1; min-width: 0; display: flex; gap: 24rpx; }
.dining-cell { flex: 1; min-width: 0; }
.dining-cell text,.dining-cell strong { display:block; }
.dining-cell text { color:#7C8A8C; font-size:22rpx; }
.dining-cell strong { margin-top:12rpx; font-size:28rpx; }
.dining-right { display: flex; align-items: center; padding-left: 24rpx; margin-left: 24rpx; border-left: 1rpx solid rgba(26,26,26,.1); }
.identity-badge { display: flex; align-items: center; gap: 12rpx; }
.badge-icon { width: 56rpx; height: 56rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 22rpx; font-weight: 700; flex: none; }
.member-icon { background: #1a1a1a; color: #b89750; }
.guest-icon { background: #EAF3DE; color: #27500A; }
.badge-info { display: flex; flex-direction: column; align-items: flex-end; }
.badge-tag { font-size: 20rpx; padding: 2rpx 12rpx; border-radius: 16rpx; font-weight: 600; }
.member-tag { background: #1a1a1a; color: #b89750; }
.guest-tag { background: #EAF3DE; color: #27500A; }
.badge-level { font-size: 18rpx; color: #999; margin-top: 4rpx; }
.section-title { display:flex; align-items:center; gap:18rpx; margin:34rpx 0 16rpx; }
.section-title::before { width:5rpx; height:34rpx; border-radius:3rpx; background:#C9A962; content:""; }
.section-head { display:flex; align-items:center; justify-content:space-between; }
.section-head .section-title { margin-right:0; margin-bottom:16rpx; margin-left:0; }
.section-note { color:#7C8A8C; font-size:22rpx; }
.dishes { padding:0 22rpx; }
.dish-item { display:flex; align-items:center; gap:16rpx; padding:20rpx 0; border-bottom:1rpx solid rgba(26,26,26,.06); }
.dish-item:last-child { border-bottom:0; }
.dish-item image { width:112rpx; height:112rpx; flex:none; border-radius:14rpx; background:#E8E4DC; }
.dish-copy { min-width:0; flex:1; }
.dish-copy strong,.dish-copy text { display:block; }
.dish-copy strong { overflow:hidden; font-size:26rpx; text-overflow:ellipsis; white-space:nowrap; }
.dish-copy text { margin-top:9rpx; color:#7C8A8C; font-size:22rpx; }
.dish-price { flex:none; font-size:27rpx; }
.remark-card { padding:22rpx; background:rgba(255,255,255,.94); }
.remark-card textarea { width:100%; height:144rpx; min-height:144rpx; padding:18rpx 22rpx; border:1rpx solid rgba(26,26,26,.09); border-radius:18rpx; color:#1A1A1A; background:rgba(255,255,255,.86); font-size:25rpx; line-height:1.6; box-sizing:border-box; }
.quick-list { display:flex; flex-wrap:wrap; gap:14rpx; margin-top:16rpx; }
.quick { min-height:60rpx; margin:0; padding:0 22rpx; border:1rpx solid rgba(79,111,82,.16); border-radius:30rpx; color:#7C8A8C; background:#FFFFFF; font-size:23rpx; line-height:58rpx; }
.quick.active { border-color:rgba(79,111,82,.36); color:#4F6F52; background:#EEF4EE; }
.amount-summary { padding:0 22rpx; }
.amount-summary view { display:flex; align-items:center; justify-content:space-between; padding:22rpx 0; border-bottom:1rpx solid rgba(26,26,26,.06); font-size:25rpx; }
.amount-summary view:last-child { border-bottom:0; }
.amount-summary text { color:#7C8A8C; }
.amount-summary strong { font-size:27rpx; }
.amount-summary .amount-total { padding-top:26rpx; font-size:28rpx; }
.amount-summary .amount-total text { color:#1A1A1A; }
.amount-summary .amount-total strong { color:#8B7355; font-size:38rpx; }
.footer { position:fixed; z-index:22; right:0; bottom:0; left:0; display:flex; align-items:center; gap:24rpx; padding:18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom)); border-top:1rpx solid rgba(26,26,26,.06); background:rgba(255,255,255,.97); box-shadow:0 -8rpx 24rpx rgba(26,26,26,.045); }
.pay-copy { min-width:0; flex:1; }
.pay-copy text,.pay-copy strong { display:block; }
.pay-copy text { color:#7C8A8C; font-size:21rpx; }
.pay-copy strong { margin-top:6rpx; color:#8B7355; font-size:36rpx; }
.pay-button { display:flex; min-height:84rpx; flex:1; align-items:center; justify-content:center; margin:0; padding:0 28rpx; border-radius:20rpx; color:#FFFFFF; background:#4F6F52; font-size:27rpx; font-weight:700; letter-spacing:2rpx; line-height:84rpx; }
