<view wx:if="{{activity}}" class="page signup"><text class="title">活动报名</text><text class="subtitle">{{activity.title}}</text><view class="card info"><text>{{activity.date}} · {{activity.time}}</text><text>{{activity.location}}</text></view><text class="section-title">报名人数</text><view class="people card"><button size="mini" data-step="-1" bindtap="people">-</button><strong>{{people}}</strong><button size="mini" data-step="1" bindtap="people">+</button></view><text class="section-title">联系信息</text><view class="inputs card"><input value="{{contact}}" bindinput="contact" placeholder="联系人"/><input value="{{mobile}}" bindinput="mobile" type="number" placeholder="手机号"/></view><button class="primary-button submit" bindtap="submit">提交报名</button></view>
