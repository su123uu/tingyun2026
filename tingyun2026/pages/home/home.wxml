<view class="page">
  <!-- 顶部Logo区域 -->
  <view class="header">
    <image class="logo" mode="aspectFit" src="/images/logo1.png" />
    <view class="header-title">停云山居</view>
    <view class="header-subtitle">青岛崂山 · 禅意生活空间</view>
  </view>

  <!-- 轮播图 - 无边框 -->
  <view class="banner-wrap">
    <swiper
      class="banner-swiper"
      indicator-dots="{{true}}"
      indicator-color="rgba(255,255,255,0.4)"
      indicator-active-color="#C9A962"
      autoplay="{{true}}"
      interval="{{4000}}"
      duration="{{500}}"
      circular="{{true}}"
    >
      <swiper-item>
        <image class="banner-img" mode="aspectFill" src="/images/banner1.png" />
      </swiper-item>
      <swiper-item>
        <image class="banner-img" mode="aspectFill" src="/images/banner2.png" />
      </swiper-item>
      <swiper-item>
        <image class="banner-img" mode="aspectFill" src="/images/banner3.png" />
      </swiper-item>
    </swiper>
  </view>

  <!-- 两大功能按钮 -->
  <view class="action-buttons">
    <view class="action-btn action-btn-primary" bindtap="goToOrder">
      <view class="action-btn-icon">
        <t-icon name="qr-code" size="48rpx" color="#fff" />
      </view>
      <view class="action-btn-text">
        <text class="action-btn-title">扫码点餐</text>
        <text class="action-btn-desc">扫桌上二维码，即刻点单</text>
      </view>
    </view>
    <view class="action-btn action-btn-gold" bindtap="goToBooking">
      <view class="action-btn-icon">
        <t-icon name="calendar" size="48rpx" color="#fff" />
      </view>
      <view class="action-btn-text">
        <text class="action-btn-title">预约预订</text>
        <text class="action-btn-desc">禅修/茶会/空间预订</text>
      </view>
    </view>
  </view>

  <!-- 山居介绍区域 -->
  <view class="intro-section">
    <!-- 区域标题 -->
    <view class="section-header">
      <view class="section-line"></view>
      <text class="section-title">停云山居</text>
      <view class="section-line"></view>
    </view>
    <view class="section-subtitle">山中何所有，岭上多白云</view>

    <!-- 关于我们卡片 - 霸王茶姬会员介绍风格 -->
    <view class="intro-card about-card">
      <view class="about-card-bg">
        <image class="about-card-img" mode="aspectFill" src="/images/tea-space.jpg" />
        <view class="about-card-overlay"></view>
      </view>
      <view class="about-card-content">
        <view class="about-card-tag">关于我们</view>
        <view class="about-card-title">隐于崂山，归于自然</view>
        <view class="about-card-desc">停云山居坐落于青岛崂山风景区，是一处集禅修、茶艺、素斋、住宿于一体的文化空间。我们以"停云"为名，取意陶渊明"停云思友"之情怀，为都市人提供一方心灵栖息之地。</view>
        <view class="about-card-footer">
          <text class="about-card-address">📍 青岛崂山风景区内</text>
        </view>
      </view>
    </view>

    <!-- 特色体验卡片 - 霸王茶姬活动介绍风格 -->
    <view class="section-header secondary-header">
      <text class="section-title-sm">特色体验</text>
      <view class="section-line-short"></view>
    </view>

    <view class="feature-cards">
      <!-- 禅修 -->
      <view class="feature-card" bindtap="goToFeature" data-feature="meditation">
        <view class="feature-card-img-wrap">
          <image class="feature-card-img" mode="aspectFill" src="/images/meditation.jpg" />
          <view class="feature-card-tag">热门</view>
        </view>
        <view class="feature-card-body">
          <view class="feature-card-icon">🧘</view>
          <view class="feature-card-title">禅修体验</view>
          <view class="feature-card-desc">专业导师带领，感受内心平静，开启内在智慧</view>
        </view>
      </view>

      <!-- 茶艺 -->
      <view class="feature-card" bindtap="goToFeature" data-feature="tea">
        <view class="feature-card-img-wrap">
          <image class="feature-card-img" mode="aspectFill" src="/images/tea.jpg" />
        </view>
        <view class="feature-card-body">
          <view class="feature-card-icon">🍵</view>
          <view class="feature-card-title">茶艺品鉴</view>
          <view class="feature-card-desc">精选好茶，在山水间品味茶道之美</view>
        </view>
      </view>

      <!-- 素斋 -->
      <view class="feature-card" bindtap="goToFeature" data-feature="dining">
        <view class="feature-card-img-wrap">
          <image class="feature-card-img" mode="aspectFill" src="/images/dinner.jpg" />
        </view>
        <view class="feature-card-body">
          <view class="feature-card-icon">🥢</view>
          <view class="feature-card-title">山居素斋</view>
          <view class="feature-card-desc">时令山野食材，匠心烹制健康美味</view>
        </view>
      </view>

      <!-- 住宿 -->
      <view class="feature-card" bindtap="goToFeature" data-feature="stay">
        <view class="feature-card-img-wrap">
          <image class="feature-card-img" mode="aspectFill" src="/images/banner2.png" />
          <view class="feature-card-tag feature-card-tag-new">新品</view>
        </view>
        <view class="feature-card-body">
          <view class="feature-card-icon">🏡</view>
          <view class="feature-card-title">山居住宿</view>
          <view class="feature-card-desc">七间雅致客房，枕山而眠，闻鸟而醒</view>
        </view>
      </view>
    </view>

    <!-- 近期活动 -->
    <view class="section-header secondary-header">
      <text class="section-title-sm">近期活动</text>
      <view class="section-line-short"></view>
    </view>

    <view class="activity-list">
      <view class="activity-card" wx:for="{{activities}}" wx:key="id" bindtap="goToActivity" data-id="{{item.id}}">
        <view class="activity-card-left">
          <image class="activity-card-img" mode="aspectFill" src="{{item.image}}" />
        </view>
        <view class="activity-card-right">
          <view class="activity-card-date">{{item.date}}</view>
          <view class="activity-card-name">{{item.title}}</view>
          <view class="activity-card-info">{{item.desc}}</view>
          <view class="activity-card-action">
            <text class="activity-card-btn">了解详情</text>
            <t-icon name="chevron-right" size="28rpx" color="#C9A962" />
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部留白 -->
  <view class="bottom-space"></view>
</view>
