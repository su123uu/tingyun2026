<view class="page">
  <swiper class="hero" autoplay circular interval="{{home.banner_interval}}" bindchange="changeBanner">
    <swiper-item wx:for="{{home.banners}}" wx:key="banner_id"><image src="{{item.image_url}}" mode="aspectFill" /></swiper-item>
  </swiper>
  <view class="hero-copy">
    <text class="hero-kicker">{{activeBanner.kicker}}</text>
    <text class="hero-title">{{activeBanner.title}}</text>
    <text class="hero-text">{{activeBanner.description}}</text>
  </view>
  <view class="quick card">
    <view wx:for="{{home.quick_entries}}" wx:key="entry_id" class="quick-item {{item.tone === 'booking' ? 'booking' : ''}}" data-action="{{item.action}}" bindtap="goEntry"><view class="quick-icon"><t-icon name="{{item.icon}}" size="44rpx" /></view><text class="quick-title">{{item.title}}</text><text>{{item.description}}</text></view>
  </view>
  <view wx:for="{{home.feature_cards}}" wx:key="card_id" class="home-section">
    <view class="home-card card" data-action="{{item.action}}" bindtap="goEntry">
      <image src="{{item.image_url}}" mode="aspectFill" />
      <view class="home-card-body">
        <text class="home-card-title">{{item.title}}</text>
        <text class="home-card-more">{{item.action === 'intro' ? '查看山居介绍 >' : '查看活动 >'}}</text>
      </view>
    </view>
  </view>
</view>
