.page { padding-bottom: calc(230rpx + env(safe-area-inset-bottom)); }
.hero { height: 900rpx; background: #24331F; }
.hero image { width: 100%; height: 100%; }
.hero-copy { position: absolute; top: 500rpx; left: 0; right: 0; display: flex; flex-direction: column; padding: 46rpx; color: #FFFFFF; text-shadow: 0 4rpx 20rpx rgba(0,0,0,.36); }
.hero-kicker { align-self: flex-start; padding: 7rpx 16rpx; border-radius: 18rpx; background: rgba(255,255,255,.16); font-size: 21rpx; letter-spacing: 4rpx; }
.hero-title { margin-top: 20rpx; font-size: 58rpx; font-weight: 700; letter-spacing: 8rpx; line-height: 1.28; white-space: pre-line; }
.hero-text { margin-top: 16rpx; color: rgba(255,255,255,.82); font-size: 23rpx; }
.quick { position: relative; z-index: 3; display: flex; margin: -92rpx 28rpx 0; overflow: hidden; }
.quick-item { display: flex; min-height: 246rpx; flex: 1; align-items: center; justify-content: center; flex-direction: column; color: #7C8A8C; font-size: 22rpx; }
.quick-icon { display:flex; width:72rpx; height:72rpx; align-items:center; justify-content:center; border:2rpx solid currentColor; border-radius:50%; color:#4F6F52; font-size:30rpx; }
.booking .quick-icon { color:#8B7355; }
.booking { border-left: 1rpx solid rgba(26,26,26,.07); }
.quick-title { margin: 18rpx 0 10rpx; color: #1A1A1A; font-size: 34rpx; font-weight: 700; }
.home-section { margin: 38rpx 28rpx 0; }
.section-head { display: flex; justify-content: space-between; margin-bottom: 16rpx; font-size: 31rpx; font-weight: 700; letter-spacing: 3rpx; }
.more { color: #7C8A8C; font-size: 22rpx; font-weight: 400; letter-spacing: 0; }
.home-card { overflow: hidden; }
.home-card image { display: block; width: 100%; height: 286rpx; }
.home-card-body { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; padding: 26rpx 30rpx; }
.home-card-title { min-width: 0; flex: 1; color: #1A1A1A; font-size: 30rpx; font-weight: 700; letter-spacing: 2rpx; }
.home-card-more { flex: none; color: #4F6F52; font-size: 23rpx; font-weight: 600; letter-spacing: 0; }
