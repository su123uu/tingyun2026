/* 停云山居首页样式 - 中国风典雅设计 */
/* 配色: 山居绿 #4F6F52 | 金色 #C9A962 | 宣纸白 #F8F6F1 | 暖米色 #E8E4DC | 墨黑 #1A1A1A */

page {
  background-color: #F8F6F1;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Noto Serif SC', serif;
  color: #1A1A1A;
}

.page {
  padding-bottom: 40rpx;
}

/* ========== 顶部Logo ========== */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx 24rpx;
  background: linear-gradient(180deg, #F8F6F1 0%, #F8F6F1 100%);
}

.logo {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A1A;
  letter-spacing: 8rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: #7C8A8C;
  margin-top: 8rpx;
  letter-spacing: 4rpx;
}

/* ========== 轮播图 - 无边框 ========== */
.banner-wrap {
  margin: 0 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-swiper {
  width: 100%;
  height: 360rpx;
  border-radius: 24rpx;
  /* 无边框 */
  border: none;
}

.banner-img {
  width: 100%;
  height: 100%;
}

/* ========== 两大功能按钮 ========== */
.action-buttons {
  display: flex;
  gap: 20rpx;
  padding: 32rpx 24rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 20rpx;
  border-radius: 20rpx;
  position: relative;
  overflow: hidden;
  min-height: 180rpx;
  box-shadow: 0 8rpx 32rpx rgba(79, 111, 82, 0.2);
  transition: transform 0.2s ease;
}

.action-btn:active {
  transform: scale(0.96);
}

.action-btn-primary {
  background: linear-gradient(135deg, #4F6F52 0%, #5C8060 50%, #6B9470 100%);
}

.action-btn-gold {
  background: linear-gradient(135deg, #C9A962 0%, #D4B872 50%, #B8963E 100%);
}

.action-btn-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.action-btn-text {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-btn-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

.action-btn-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 6rpx;
}

/* ========== 山居介绍区域 ========== */
.intro-section {
  padding: 0 24rpx;
}

/* 区域标题 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 20rpx 0 8rpx;
}

.section-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #C9A962, transparent);
  max-width: 120rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
  letter-spacing: 8rpx;
}

.section-subtitle {
  text-align: center;
  font-size: 24rpx;
  color: #7C8A8C;
  margin-bottom: 24rpx;
  letter-spacing: 4rpx;
  font-style: italic;
}

.secondary-header {
  justify-content: flex-start;
  padding: 32rpx 0 16rpx;
  gap: 16rpx;
}

.section-title-sm {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
  letter-spacing: 4rpx;
  flex-shrink: 0;
}

.section-line-short {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(90deg, #E8E4DC, transparent);
}

/* ========== 关于我们卡片 - 霸王茶姬风格 ========== */
.intro-card {
  border-radius: 20rpx;
  overflow: hidden;
  background: #FFFFFF;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.about-card {
  margin-bottom: 32rpx;
}

.about-card-bg {
  position: relative;
  width: 100%;
  height: 320rpx;
  overflow: hidden;
}

.about-card-img {
  width: 100%;
  height: 100%;
}

.about-card-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(0deg, rgba(0,0,0,0.55) 0%, transparent 100%);
}

.about-card-content {
  padding: 24rpx 28rpx 28rpx;
}

.about-card-tag {
  display: inline-block;
  background: linear-gradient(135deg, #4F6F52, #5C8060);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.about-card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.about-card-desc {
  font-size: 26rpx;
  color: #4A4A4A;
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.about-card-footer {
  padding-top: 16rpx;
  border-top: 2rpx solid #F0EDE8;
}

.about-card-address {
  font-size: 24rpx;
  color: #7C8A8C;
}

/* ========== 特色体验卡片 - 霸王茶姬活动风格 ========== */
.feature-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.feature-card {
  width: calc(50% - 8rpx);
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s ease;
}

.feature-card:active {
  transform: scale(0.97);
}

.feature-card-img-wrap {
  position: relative;
  width: 100%;
  height: 200rpx;
  overflow: hidden;
}

.feature-card-img {
  width: 100%;
  height: 100%;
}

.feature-card-tag {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: linear-gradient(135deg, #E8734A, #F0956A);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  letter-spacing: 1rpx;
}

.feature-card-tag-new {
  background: linear-gradient(135deg, #4F6F52, #5C8060);
}

.feature-card-body {
  padding: 16rpx 20rpx 20rpx;
}

.feature-card-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.feature-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 6rpx;
}

.feature-card-desc {
  font-size: 22rpx;
  color: #7C8A8C;
  line-height: 1.4;
}

/* ========== 近期活动列表 - 霸王茶姬风格 ========== */
.activity-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.activity-card {
  display: flex;
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s ease;
}

.activity-card:active {
  transform: scale(0.98);
}

.activity-card-left {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.activity-card-img {
  width: 100%;
  height: 100%;
}

.activity-card-right {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.activity-card-date {
  font-size: 22rpx;
  color: #C9A962;
  font-weight: 500;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.activity-card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.activity-card-info {
  font-size: 22rpx;
  color: #7C8A8C;
  line-height: 1.4;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.activity-card-action {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.activity-card-btn {
  font-size: 24rpx;
  color: #C9A962;
  font-weight: 500;
}

/* ========== 底部留白 ========== */
.bottom-space {
  height: 48rpx;
}
