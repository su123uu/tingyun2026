page {
  --td-calendar-active-color: #4F6F52;
  --td-calendar-item-centre-color: rgba(79, 111, 82, .14);
  --td-calendar-selected-color: #FFFFFF;
  --td-calendar-title-color: #1A1A1A;
  --td-calendar-days-color: #7C8A8C;
  --td-brand-color: #4F6F52;
  --td-brand-color-active: #38523C;
  --td-brand-color-disabled: #A9B9AA;
  --td-brand-color-light: rgba(79, 111, 82, .14);
  --td-brand-color-light-active: rgba(79, 111, 82, .22);
  --td-button-primary-bg-color: #4F6F52;
  --td-button-primary-border-color: #4F6F52;
  --td-button-primary-active-bg-color: #38523C;
  --td-button-primary-active-border-color: #38523C;
  --td-button-primary-disabled-bg: #A9B9AA;
  --td-button-primary-disabled-border-color: #A9B9AA;
}
.form-page {
  min-height: 100vh;
  padding-bottom: calc(176rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(ellipse at 18% 18%, rgba(79, 111, 82, .07), transparent 34%),
    linear-gradient(180deg, #F8F6F1, #F3F1EC);
}
.hero {
  position: fixed;
  z-index: 20;
  top: 0;
  right: 0;
  left: 0;
  overflow: hidden;
  color: #FFFFFF;
  border-radius: 0 0 38rpx 38rpx;
  background: linear-gradient(145deg, #4F6F52, #2D4A30);
  box-shadow: 0 10rpx 26rpx rgba(45, 74, 48, .12);
  transition: height .08s linear;
}
.hero::after {
  position: absolute;
  top: -120rpx;
  right: -90rpx;
  width: 420rpx;
  height: 420rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, .08), transparent 68%);
  content: "";
}
.hero-nav { position: absolute; z-index: 2; right: 0; left: 0; display: flex; align-items: center; padding: 0 20rpx; }
.back { display: flex; width: 66rpx; height: 66rpx; align-items: center; justify-content: center; }
.back-arrow { width: 20rpx; height: 20rpx; border-bottom: 3rpx solid rgba(255, 255, 255, .86); border-left: 3rpx solid rgba(255, 255, 255, .86); transform: rotate(45deg); }
.hero-title,.hero-subtitle,.hero-line { position: absolute; z-index: 1; left: 28rpx; transition: all .08s linear; }
.hero-title { color: #FFFFFF; font-weight: 700; letter-spacing: 8rpx; line-height: 1.2; }
.hero-subtitle { color: rgba(255, 255, 255, .64); font-size: 23rpx; letter-spacing: 5rpx; }
.hero-line { width: 60rpx; height: 2rpx; background: #C9A962; }
.section-title { display: flex; align-items: center; gap: 18rpx; }
.section-title::before { width: 5rpx; height: 34rpx; border-radius: 3rpx; background: #C9A962; content: ""; }
.date-card { display: flex; align-items: center; justify-content: space-between; margin: 0 28rpx; padding: 26rpx 32rpx 22rpx; border: 1rpx solid rgba(26, 26, 26, .045); background: rgba(255, 255, 255, .90); }
.date-col { display: flex; min-width: 150rpx; align-items: center; flex-direction: column; }
.date-label { color: #7C8A8C; font-size: 21rpx; letter-spacing: 4rpx; }
.date-value { margin-top: 10rpx; color: #1A1A1A; font-size: 34rpx; font-weight: 700; letter-spacing: 3rpx; }
.date-center { display: flex; align-items: center; align-self: stretch; justify-content: flex-end; flex-direction: column; padding-bottom: 4rpx; }
.date-arrow { color: #C9A962; font-size: 32rpx; line-height: 1; }
.date-night { margin-top: 9rpx; color: #4F6F52; font-size: 20rpx; letter-spacing: 2rpx; white-space: nowrap; }
.people { display: flex; align-items: center; justify-content: center; gap: 34rpx; margin: 0 28rpx; padding: 18rpx 24rpx; border: 1rpx solid rgba(26, 26, 26, .045); background: rgba(255, 255, 255, .90); }
.people-button { width: 60rpx; height: 60rpx; margin: 0; padding: 0; color: #4F6F52; background: transparent; font-size: 40rpx; line-height: 56rpx; }
.people-input { width: 88rpx; height: 60rpx; color: #1A1A1A; font-size: 34rpx; font-weight: 700; line-height: 60rpx; text-align: center; }
.list { display: grid; gap: 20rpx; margin: 0 28rpx; }
.select { display: flex; min-height: 154rpx; align-items: center; gap: 22rpx; padding: 20rpx; border: 2rpx solid transparent; border-radius: 26rpx; background: rgba(255, 255, 255, .90); box-shadow: 0 8rpx 24rpx rgba(26, 26, 26, .045); }
.room-image { width: 144rpx; height: 108rpx; flex: none; border-radius: 16rpx; background: #E8E4DC; }
.room-info { min-width: 0; flex: 1; }
.select strong,.select text,.select small { display: block; }
.select strong { font-size: 29rpx; letter-spacing: 4rpx; }
.select text { margin-top: 9rpx; color: #7C8A8C; font-size: 22rpx; }
.select small { color: #4F6F52; font-size: 22rpx; }
.room-price { display: flex; flex-wrap: wrap; gap: 15rpx; margin-top: 12rpx; }
.regular-price { color: #7C8A8C !important; }
.room-check { display: flex; width: 42rpx; height: 42rpx; flex: none; align-items: center; justify-content: center; border: 2rpx solid #E8E4DC; border-radius: 50%; color: #FFFFFF; font-size: 26rpx; line-height: 1; }
.select.selected { border-color: #4F6F52; background: #F7FBF6; }
.select.selected .room-check { border-color: #4F6F52; background: #4F6F52; }
.inputs { margin: 0 28rpx; padding: 0 20rpx; }
.inputs input { padding: 22rpx 0; border-bottom: 1rpx solid rgba(26, 26, 26, .06); font-size: 25rpx; }
.remark-card { margin: 0 28rpx 18rpx; padding: 22rpx; background: rgba(255, 255, 255, .94); }
.remark-card textarea { width: 100%; height: 144rpx; min-height: 144rpx; padding: 18rpx 22rpx; border: 1rpx solid rgba(26, 26, 26, .09); border-radius: 18rpx; color: #1A1A1A; background: rgba(255, 255, 255, .86); font-size: 25rpx; line-height: 1.6; box-sizing: border-box; }
.footer { position: fixed; z-index: 22; right: 0; bottom: 0; left: 0; display: flex; align-items: center; gap: 24rpx; padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom)); border-top: 1rpx solid rgba(26, 26, 26, .06); background: rgba(255, 255, 255, .97); box-shadow: 0 -8rpx 24rpx rgba(26, 26, 26, .045); }
.pay-copy { min-width: 0; flex: 1; }
.pay-copy text,.pay-copy strong { display: block; }
.pay-copy text { color: #7C8A8C; font-size: 21rpx; }
.pay-copy strong { margin-top: 6rpx; color: #4F6F52; font-size: 36rpx; }
.pay-button { display: flex; min-height: 84rpx; flex: 1; align-items: center; justify-content: center; margin: 0; padding: 0 28rpx; border-radius: 20rpx; color: #FFFFFF; background: #4F6F52; font-size: 27rpx; font-weight: 700; letter-spacing: 2rpx; line-height: 84rpx; }
.room-mask { position: fixed; z-index: 51; top: 0; right: 0; bottom: 0; left: 0; background: rgba(26, 26, 26, .38); }
.room-dialog { position: fixed; z-index: 52; right: 0; bottom: 0; left: 0; overflow: hidden; padding: 24rpx 28rpx calc(24rpx + env(safe-area-inset-bottom)); border-radius: 34rpx 34rpx 0 0; background: #FFFFFF; box-shadow: 0 -18rpx 48rpx rgba(26, 26, 26, .16); }
.room-dialog-close { position: absolute; z-index: 1; top: 36rpx; right: 40rpx; display: flex; width: 58rpx; height: 58rpx; align-items: center; justify-content: center; border-radius: 50%; color: #FFFFFF; background: rgba(26, 26, 26, .48); font-size: 42rpx; line-height: 1; }
.room-cover { display: block; width: 100%; height: 330rpx; border-radius: 22rpx; background: #E8E4DC; }
.room-detail-name,.room-detail-type { display: block; }
.room-detail-name { margin-top: 22rpx; font-size: 36rpx; font-weight: 700; letter-spacing: 7rpx; }
.room-detail-type { margin-top: 8rpx; color: #7C8A8C; font-size: 23rpx; letter-spacing: 2rpx; }
.room-detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; margin-top: 22rpx; }
.room-detail-item { padding: 18rpx; border-radius: 16rpx; background: rgba(79, 111, 82, .06); }
.room-detail-item text,.room-detail-item strong { display: block; }
.room-detail-item text { color: #7C8A8C; font-size: 20rpx; letter-spacing: 2rpx; }
.room-detail-item strong { margin-top: 8rpx; color: #4F6F52; font-size: 25rpx; }
.room-detail-actions { display: flex; gap: 16rpx; margin-top: 24rpx; }
.room-detail-button { flex: 1; min-height: 82rpx; margin: 0; border-radius: 16rpx; font-size: 27rpx; letter-spacing: 4rpx; line-height: 82rpx; }
.room-detail-button.cancel { border: 1rpx solid rgba(79, 111, 82, .26); color: #4F6F52; background: #FFFFFF; }
.room-detail-button.reserve { color: #FFFFFF; background: #4F6F52; }
