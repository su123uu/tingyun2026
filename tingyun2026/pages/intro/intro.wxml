<view class="page">
  <image wx:if="{{page.cover_image_url}}" class="cover" src="{{page.cover_image_url}}" mode="aspectFill" />
  <view wx:else class="cover empty-cover"></view>

  <view class="hero-copy">
    <text class="eyebrow">TINGYUN SHANJU</text>
    <text class="title">{{page.title}}</text>
    <text wx:if="{{page.summary}}" class="summary">{{page.summary}}</text>
  </view>

  <view wx:if="{{loading}}" class="notice">内容加载中...</view>
  <view wx:elif="{{loadError}}" class="notice">{{loadError}}</view>

  <view class="content">
    <block wx:for="{{page.content_blocks}}" wx:key="index">
      <view wx:if="{{item.type === 'lead'}}" class="lead">
        <text>{{item.text}}</text>
      </view>

      <text wx:elif="{{item.type === 'section_title'}}" class="section-title">{{item.text || item.title}}</text>

      <view wx:elif="{{item.type === 'paragraph'}}" class="paragraph">
        <text>{{item.text}}</text>
      </view>

      <view wx:elif="{{item.type === 'quote'}}" class="quote">
        <text>{{item.text}}</text>
      </view>

      <image wx:elif="{{item.type === 'image' && item.image_url}}" class="wide-image" src="{{item.image_url}}" mode="widthFix" />

      <view wx:elif="{{item.type === 'feature_grid'}}" class="feature-grid">
        <view wx:for="{{item.items}}" wx:key="index" wx:for-item="feature" class="feature-card">
          <text class="feature-title">{{feature.title}}</text>
          <text class="feature-text">{{feature.text}}</text>
        </view>
      </view>

      <view wx:elif="{{item.type === 'space_list'}}" class="space-list">
        <view wx:for="{{item.items}}" wx:key="index" wx:for-item="space" class="space-item">
          <text class="space-title">{{space.title}}</text>
          <text class="space-text">{{space.text}}</text>
        </view>
      </view>

      <view wx:elif="{{item.type === 'list'}}" class="list">
        <view wx:for="{{item.items}}" wx:key="index" wx:for-item="listItem" class="list-item">
          <text class="dot"></text>
          <text>{{listItem}}</text>
        </view>
      </view>

      <rich-text wx:elif="{{item.type === 'rich_text'}}" class="rich-text" nodes="{{item.rich_nodes}}"></rich-text>

      <view wx:elif="{{item.type === 'contact'}}" class="contact-card">
        <image wx:if="{{item.image_url}}" src="{{item.image_url}}" mode="widthFix" />
        <view class="contact-copy">
          <text class="contact-title">{{item.title}}</text>
          <text class="contact-text">{{item.text}}</text>
          <button class="contact-button" plain bindtap="copyContact">复制联系方式</button>
        </view>
      </view>
    </block>
    <view wx:if="{{!loading && !loadError && page.content_blocks.length === 0}}" class="notice">介绍内容正在整理中。</view>
  </view>
</view>
