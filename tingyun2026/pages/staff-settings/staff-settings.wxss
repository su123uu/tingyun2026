.settings { padding:42rpx 28rpx; }
.info { margin-top:34rpx; padding:30rpx; color:#5F625E; font-size:25rpx; line-height:1.8; }
.share-row { display:flex; align-items:center; justify-content:space-between; gap:16rpx; width:100%; margin-top:34rpx; padding:30rpx 32rpx; border:1rpx solid rgba(139,115,85,.18); border-radius:22rpx; background:#FFFFFF; box-shadow:0 8rpx 20rpx rgba(26,26,26,.04); box-sizing:border-box; }
.share-row::after { border:0; }
.share-row-main { display:flex; flex:1; flex-direction:column; align-items:flex-start; min-width:0; }
.share-row-title { color:#4A4A4A; font-size:27rpx; font-weight:700; }
.share-row-copy { margin-top:8rpx; color:#8A918B; font-size:22rpx; line-height:1.5; }
.share-row-arrow { color:#8B7355; font-size:40rpx; line-height:1; }
