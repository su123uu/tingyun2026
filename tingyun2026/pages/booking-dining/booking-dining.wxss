page {
  --td-calendar-active-color: #8B7355;
  --td-calendar-selected-color: #FFFFFF;
  --td-brand-color: #8B7355;
  --td-brand-color-active: #665239;
  --td-brand-color-disabled: #C9BDAE;
  --td-brand-color-light: #F7F2EA;
  --td-brand-color-light-active: #EEE5D9;
  --td-button-primary-bg-color: #8B7355;
  --td-button-primary-border-color: #8B7355;
  --td-button-primary-active-bg-color: #665239;
  --td-button-primary-active-border-color: #665239;
}
.form-page {
  min-height: 100vh;
  padding-bottom: calc(176rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(ellipse at 18% 18%, rgba(139, 115, 85, .08), transparent 34%),
    linear-gradient(180deg, #F8F6F1, #F3F1EC);
}
.hero {
  position: fixed;
  z-index: 20;
  top: 0;
  right: 0;
  left: 0;
  overflow: hidden;
  color: #FFFFFF;
  border-radius: 0 0 38rpx 38rpx;
  background: linear-gradient(145deg, #8B7355, #665239);
  box-shadow: 0 10rpx 26rpx rgba(102, 82, 57, .14);
  transition: height .08s linear;
}
.hero::after {
  position: absolute;
  top: -120rpx;
  right: -90rpx;
  width: 420rpx;
  height: 420rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, .08), transparent 68%);
  content: "";
}
.hero-nav { position: absolute; z-index: 2; right: 0; left: 0; display: flex; align-items: center; padding: 0 20rpx; }
.back { display: flex; width: 66rpx; height: 66rpx; align-items: center; justify-content: center; }
.back-arrow { width: 20rpx; height: 20rpx; border-bottom: 3rpx solid rgba(255, 255, 255, .86); border-left: 3rpx solid rgba(255, 255, 255, .86); transform: rotate(45deg); }
.hero-title,.hero-subtitle,.hero-line { position: absolute; z-index: 1; left: 28rpx; transition: all .08s linear; }
.hero-title { color: #FFFFFF; font-weight: 700; letter-spacing: 8rpx; line-height: 1.2; }
.hero-subtitle { color: rgba(255, 255, 255, .64); font-size: 23rpx; letter-spacing: 5rpx; }
.hero-line { width: 60rpx; height: 2rpx; background: #C9A962; }
.section-title { display: flex; align-items: center; gap: 18rpx; }
.section-title::before { width: 5rpx; height: 34rpx; border-radius: 3rpx; background: #C9A962; content: ""; }
.date-card { display: flex; align-items: center; justify-content: space-between; margin: 0 28rpx; padding: 24rpx 28rpx; border: 1rpx solid rgba(26, 26, 26, .045); background: rgba(255, 255, 255, .90); }
.date-label,.date-value { display: block; }
.date-label { color: #7C8A8C; font-size: 21rpx; letter-spacing: 4rpx; }
.date-value { margin-top: 10rpx; color: #1A1A1A; font-size: 34rpx; font-weight: 700; letter-spacing: 3rpx; }
.date-action { display: flex; align-items: center; gap: 10rpx; color: #8B7355; font-size: 22rpx; letter-spacing: 2rpx; }
.date-arrow { font-size: 42rpx; font-weight: 300; line-height: 1; }
.slots { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; margin: 0 28rpx; }
.slot { display: flex; align-items: center; justify-content: center; flex-direction: column; padding: 22rpx 16rpx; border: 2rpx solid rgba(139, 115, 85, .18); border-radius: 20rpx; color: #8B7355; background: rgba(255, 255, 255, .90); box-shadow: 0 8rpx 24rpx rgba(26, 26, 26, .045); transition: all .18s ease; }
.slot-name { font-size: 28rpx; font-weight: 700; letter-spacing: 5rpx; }
.slot-time { margin-top: 8rpx; color: #A38E74; font-size: 19rpx; letter-spacing: 1rpx; }
.slot.on { border-color: #8B7355; color: #FFFFFF; background: #8B7355; box-shadow: 0 10rpx 24rpx rgba(139, 115, 85, .18); }
.slot.on .slot-time { color: rgba(255, 255, 255, .68); }
.people { display: flex; align-items: center; justify-content: center; gap: 34rpx; margin: 0 28rpx; padding: 18rpx 24rpx; border: 1rpx solid rgba(26, 26, 26, .045); background: rgba(255, 255, 255, .90); }
.people-button { width: 60rpx; height: 60rpx; margin: 0; padding: 0; color: #4F6F52; background: transparent; font-size: 40rpx; line-height: 56rpx; }
.people-input { width: 88rpx; height: 60rpx; color: #1A1A1A; font-size: 34rpx; font-weight: 700; line-height: 60rpx; text-align: center; }
.people-hint { display: block; margin: 12rpx 28rpx 0; color: #A38E74; font-size: 21rpx; text-align: right; }
.list { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; margin: 0 28rpx; }
.select { position: relative; overflow: hidden; padding: 0 0 18rpx; border: 2rpx solid transparent; border-radius: 22rpx; background: rgba(255, 255, 255, .90); box-shadow: 0 8rpx 24rpx rgba(26, 26, 26, .045); }
.room-cover { position: relative; }
.room-image { display: block; width: 100%; height: 176rpx; background: #E8E4DC; }
.room-info { min-width: 0; padding: 16rpx 16rpx 0; }
.select strong,.select text,.select small { display: block; }
.select strong { font-size: 27rpx; letter-spacing: 4rpx; }
.select text { margin-top: 8rpx; overflow: hidden; color: #7C8A8C; font-size: 20rpx; text-overflow: ellipsis; white-space: nowrap; }
.select small { margin-top: 10rpx; color: #8B7355; font-size: 21rpx; }
.select .room-status { position: absolute; top: 14rpx; left: 14rpx; margin: 0; padding: 6rpx 12rpx; overflow: visible; border-radius: 999rpx; color: #FFFFFF; background: rgba(74, 85, 79, .82); font-size: 19rpx; letter-spacing: 1rpx; line-height: 1.2; }
.room-check,.standard-check { display: flex; flex: none; align-items: center; justify-content: center; border: 2rpx solid #E8E4DC; border-radius: 50%; color: #FFFFFF; }
.room-check { position: absolute; top: 14rpx; right: 14rpx; width: 40rpx; height: 40rpx; border-color: rgba(255, 255, 255, .82); background: rgba(26, 26, 26, .20); font-size: 25rpx; line-height: 1; }
.select.selected { border-color: #8B7355; color: #FFFFFF; background: #8B7355; box-shadow: 0 12rpx 28rpx rgba(139, 115, 85, .20); }
.select.selected text { color: rgba(255, 255, 255, .68); }
.select.selected small { color: rgba(255, 255, 255, .88); }
.select.selected .room-check,.standard.selected .standard-check { border-color: #8B7355; background: #8B7355; }
.select.disabled { color: #7C8A8C; background: rgba(235, 233, 228, .92); box-shadow: none; }
.select.disabled .room-image { filter: grayscale(1); opacity: .58; }
.select.disabled .room-check { display: none; }
.select.disabled small { color: #A3AAA5; }
.room-hint { display: block; margin: 14rpx 28rpx 0; color: #A38E74; font-size: 21rpx; text-align: right; }
.standard-list { display: grid; gap: 16rpx; margin: 0 28rpx; }
.standard { display: flex; min-height: 150rpx; align-items: center; gap: 18rpx; padding: 16rpx; border: 2rpx solid transparent; background: rgba(255, 255, 255, .90); }
.standard-image { width: 148rpx; height: 148rpx; flex: none; border-radius: 16rpx; background: #E8E4DC; }
.standard-info { min-width: 0; flex: 1; }
.standard strong,.standard text,.standard small { display: block; }
.standard strong { font-size: 28rpx; letter-spacing: 4rpx; }
.standard text { display: -webkit-box; margin-top: 9rpx; overflow: hidden; color: #7C8A8C; font-size: 21rpx; line-height: 1.45; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }
.standard-foot { display: flex; align-items: center; justify-content: space-between; gap: 10rpx; margin-top: 13rpx; }
.standard-price { color: #8B7355; font-size: 23rpx; font-weight: 700; }
.standard-detail-link { color: #8B7355; font-size: 20rpx; }
.standard-check { width: 34rpx; height: 34rpx; font-size: 21rpx; line-height: 1; }
.standard.selected { border-color: #8B7355; background: #FFFCF7; }
.inputs { margin: 0 28rpx; padding: 0 20rpx; }
.inputs input { padding: 22rpx 0; border-bottom: 1rpx solid rgba(26, 26, 26, .06); font-size: 25rpx; }
.remark-card { margin: 0 28rpx 18rpx; padding: 22rpx; background: rgba(255, 255, 255, .94); }
.remark-card textarea { width: 100%; height: 144rpx; min-height: 144rpx; padding: 18rpx 22rpx; border: 1rpx solid rgba(26, 26, 26, .09); border-radius: 18rpx; color: #1A1A1A; background: rgba(255, 255, 255, .86); font-size: 25rpx; line-height: 1.6; box-sizing: border-box; }
.footer { position: fixed; z-index: 22; right: 0; bottom: 0; left: 0; display: flex; align-items: center; gap: 24rpx; padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom)); border-top: 1rpx solid rgba(26, 26, 26, .06); background: rgba(255, 255, 255, .97); box-shadow: 0 -8rpx 24rpx rgba(26, 26, 26, .045); }
.pay-copy { min-width: 0; flex: 1; }
.pay-copy text,.pay-copy strong { display: block; }
.pay-copy text { color: #7C8A8C; font-size: 21rpx; }
.pay-copy strong { margin-top: 6rpx; color: #8B7355; font-size: 36rpx; }
.pay-button { display: flex; min-height: 84rpx; flex: 1; align-items: center; justify-content: center; margin: 0; padding: 0 28rpx; border-radius: 20rpx; color: #FFFFFF; background: #4F6F52; font-size: 27rpx; font-weight: 700; letter-spacing: 2rpx; line-height: 84rpx; }
.standard-mask { position: fixed; z-index: 51; top: 0; right: 0; bottom: 0; left: 0; background: rgba(0, 0, 0, .46); }
.standard-dialog { position: fixed; z-index: 52; right: 0; bottom: 0; left: 0; display: flex; min-height: 620rpx; max-height: 82vh; overflow-y: auto; flex-direction: column; padding: 28rpx 28rpx calc(28rpx + env(safe-area-inset-bottom)); border-radius: 30rpx 30rpx 0 0; background: #FFFFFF; box-shadow: 0 -12rpx 36rpx rgba(26, 26, 26, .14); box-sizing: border-box; animation: standard-slide-up .22s ease-out; }
.standard-summary { display: flex; gap: 22rpx; }
.standard-detail-image { display: block; width: 246rpx; height: 246rpx; flex: none; border-radius: 20rpx; background: #E8E4DC; }
.standard-detail-body { display: flex; min-width: 0; flex: 1; flex-direction: column; }
.standard-detail-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 16rpx; }
.standard-detail-name { color: #1A1A1A; font-size: 32rpx; font-weight: 700; letter-spacing: 3rpx; }
.standard-detail-head text:last-child { color: #7C8A8C; font-size: 44rpx; line-height: 32rpx; }
.standard-detail-desc { margin-top: 12rpx; color: #7C8A8C; font-size: 23rpx; line-height: 1.6; }
.standard-detail-price { margin-top: auto; color: #8B7355; font-size: 44rpx; font-weight: 700; }
.standard-detail-unit { font-size: 23rpx; }
.standard-detail-list { margin-top: 26rpx; padding-top: 22rpx; border-top: 1rpx solid rgba(26, 26, 26, .08); }
.standard-detail-title { display: block; margin-bottom: 12rpx; font-size: 25rpx; }
.standard-detail-row { display: flex; gap: 24rpx; padding: 9rpx 0; color: #4A554F; font-size: 24rpx; }
.standard-detail-row text:first-child { min-width: 150rpx; color: #7C8A8C; }
.standard-detail-button { display: flex; width: 100%; height: 86rpx; min-height: 86rpx; align-items: center; justify-content: center; margin: 36rpx 0 0; padding: 0; border-radius: 16rpx; color: #FFFFFF; background: #8B7355; font-size: 27rpx; font-weight: 700; letter-spacing: 3rpx; line-height: 1.2; }
.standard-detail-button::after { border: 0; }
@keyframes standard-slide-up { from { transform: translateY(100%); } to { transform: translateY(0); } }
