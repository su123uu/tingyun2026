.detail-page { padding-bottom:36rpx; background:linear-gradient(180deg,#F8F6F1,#F3F0E9); }
.topbar { position:sticky; z-index:20; top:0; border-bottom:1rpx solid rgba(26,26,26,.045); background:rgba(248,246,241,.95); backdrop-filter:blur(24rpx); }
.head { display:flex; flex-direction:column; padding:0 188rpx 18rpx 20rpx; }
.nav-row { display:flex; align-items:center; gap:4rpx; }
.back { display:flex; width:48rpx; height:100%; flex:none; align-items:center; justify-content:center; }
.back-arrow { width:18rpx; height:18rpx; border-bottom:3rpx solid #4A554F; border-left:3rpx solid #4A554F; transform:rotate(45deg); }
.title,.subtitle { display:block; }
.title { font-size:40rpx; letter-spacing:4rpx; }
.subtitle { margin:12rpx 0 0 8rpx; overflow:hidden; font-size:22rpx; letter-spacing:1rpx; text-overflow:ellipsis; white-space:nowrap; }
.status-banner { display:flex; flex-direction:column; margin:0 28rpx; padding:34rpx 36rpx; border-radius:26rpx; color:#FFFFFF; background:linear-gradient(135deg,#597A5C,#38523C); box-shadow:0 8rpx 24rpx rgba(26,26,26,.045); }
.status-title { font-size:40rpx; font-weight:700; letter-spacing:4rpx; }
.status-desc { margin-top:14rpx; color:rgba(255,255,255,.72); font-size:23rpx; line-height:1.6; }
.content { padding:0 28rpx 24rpx; }
.section-title { display:flex; align-items:center; gap:18rpx; margin:34rpx 0 16rpx; font-size:30rpx; font-weight:700; letter-spacing:3rpx; }
.section-title::before { width:5rpx; height:34rpx; border-radius:3rpx; background:#C9A962; content:""; }
.detail-card { padding:8rpx 28rpx; }
.dish-batch { padding:10rpx 0 16rpx; border-bottom:1rpx solid rgba(26,26,26,.06); }
.dish-batch:last-child { border-bottom:0; }
.batch-head { display:flex; align-items:center; justify-content:space-between; padding:8rpx 0 14rpx; color:#8B7355; font-size:24rpx; font-weight:700; }
.info-line { display:flex; justify-content:space-between; gap:24rpx; padding:22rpx 0; border-bottom:1rpx solid rgba(26,26,26,.06); font-size:25rpx; line-height:1.55; }
.info-line:last-child { border-bottom:0; }
.info-label { flex:none; color:#7C8A8C; }
.info-line strong { color:#8B7355; }
.remark-line text:last-child { text-align:right; }
.dish { display:flex; align-items:center; gap:18rpx; padding:20rpx 0; border-bottom:1rpx solid rgba(26,26,26,.06); }
.dish:last-child { border-bottom:0; }
.dish image { width:108rpx; height:108rpx; flex:none; border-radius:18rpx; background:#E8E4DC; }
.dish-copy { min-width:0; flex:1; }
.dish-copy strong,.dish-copy text { display:block; }
.dish-copy strong { overflow:hidden; font-size:26rpx; text-overflow:ellipsis; white-space:nowrap; }
.dish-copy text { margin-top:12rpx; color:#7C8A8C; font-size:23rpx; }
.dish-price { align-self:flex-start; flex:none; padding-top:4rpx; font-size:26rpx; }
.add-meal-button { display:flex; min-height:84rpx; align-items:center; justify-content:center; margin:22rpx 0 0; border:0; border-radius:20rpx; color:#FFFFFF; background:#4F6F52; font-size:28rpx; font-weight:700; letter-spacing:2rpx; line-height:84rpx; }
.add-meal-button::after { border:0; }
.timeline { padding:26rpx 26rpx 8rpx; }
.step { position:relative; padding:0 0 34rpx 44rpx; color:#7C8A8C; font-size:24rpx; line-height:1.45; }
.step::before { position:absolute; top:6rpx; left:4rpx; width:16rpx; height:16rpx; border:4rpx solid #CBD0CB; border-radius:50%; background:#FFFFFF; content:""; }
.step::after { position:absolute; top:30rpx; bottom:0; left:14rpx; width:2rpx; background:#D8DDD8; content:""; }
.step:last-child { padding-bottom:20rpx; }
.step:last-child::after { display:none; }
.step.done { color:#4F6F52; }
.step.done::before { border-color:#4F6F52; background:#4F6F52; }
.actions { display:flex; gap:18rpx; padding:0 28rpx 24rpx; }
.service-button { display:flex; min-height:84rpx; flex:1; align-items:center; justify-content:center; margin:0; border:1rpx solid rgba(79,111,82,.25); border-radius:20rpx; color:#4F6F52; background:#FFFFFF; font-size:27rpx; font-weight:700; letter-spacing:2rpx; line-height:84rpx; }
