.member-page { padding-bottom: 150rpx; }
.hero { position: sticky; z-index: 35; top: 0; overflow: hidden; padding-right: 44rpx; padding-bottom: 66rpx; padding-left: 44rpx; color: #F4DFA6; background: radial-gradient(circle at 88% 18%, rgba(201, 169, 98, .17), transparent 30%), linear-gradient(135deg, #171715, #2A2722); box-sizing: border-box; }
.hero-nav { display: flex; align-items: center; }
.back { display: flex; width: 68rpx; height: 100%; align-items: center; justify-content: center; margin-left: -14rpx; }
.back-arrow { width: 20rpx; height: 20rpx; border-bottom: 3rpx solid #F4DFA6; border-left: 3rpx solid #F4DFA6; transform: rotate(45deg); }
.eyebrow,.hero-title,.hero-copy,.tier-copy,.benefit-no,.benefit-name { display: block; }
.eyebrow { margin-top: 36rpx; color: rgba(244, 223, 166, .62); font-size: 19rpx; letter-spacing: 6rpx; }
.hero-title { margin-top: 24rpx; font-family: "Songti SC", serif; font-size: 60rpx; font-weight: 700; }
.hero-copy { width: 82%; margin-top: 24rpx; color: rgba(255, 255, 255, .64); font-size: 25rpx; line-height: 1.8; }
.content { padding: 0 28rpx; }
.section { margin-top: 28rpx; }
.section-head { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; margin-bottom: 18rpx; }
.section-head .section-title { margin: 0; }
.section-note { color: #7C8A8C; font-size: 22rpx; }
.stack { display: grid; gap: 18rpx; }
.tier { padding: 26rpx; }
.tier-head { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.tier-name { font-size: 28rpx; font-weight: 700; }
.tier-value { color: #876A37; font-size: 27rpx; font-weight: 700; }
.tier-copy { margin-top: 14rpx; color: #7C8A8C; font-size: 23rpx; line-height: 1.6; }
.benefits { display: grid; grid-template-columns: 1fr 1fr; overflow: hidden; }
.benefit { min-height: 154rpx; padding: 24rpx 21rpx; border-right: 1rpx solid rgba(26, 26, 26, .06); border-bottom: 1rpx solid rgba(26, 26, 26, .06); box-sizing: border-box; }
.benefit:nth-child(2n) { border-right: 0; }
.benefit:nth-last-child(-n + 2) { border-bottom: 0; }
.benefit-no { color: #C9A962; font-size: 21rpx; }
.benefit-name { margin-top: 13rpx; font-size: 25rpx; font-weight: 700; line-height: 1.45; }
.rule { padding: 28rpx; color: #5F625E; font-size: 25rpx; line-height: 1.85; }
.footer { position: fixed; z-index: 40; right: 0; bottom: 0; left: 0; padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom)); border-top: 1rpx solid rgba(26, 26, 26, .06); background: rgba(255, 255, 255, .96); }
.footer button { color: #FFFFFF; background: #8B7355; font-size: 27rpx; }
