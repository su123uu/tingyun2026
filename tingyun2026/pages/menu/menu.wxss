.page { display:flex; height:100vh; min-height:0; overflow:hidden; flex-direction:column; padding-bottom:calc(126rpx + env(safe-area-inset-bottom)); }
.head { display:flex; min-height:88rpx; flex:none; justify-content:flex-end; flex-direction:column; padding:0 188rpx 18rpx 28rpx; background:#F8F6F1; }
.table { display:flex; flex:none; align-items:center; justify-content:space-between; margin:0 28rpx 20rpx; padding:22rpx; }
.table-left { flex: 1; min-width: 0; }
.table-right { display: flex; align-items: center; padding-left: 24rpx; margin-left: 20rpx; border-left: 1rpx solid rgba(26,26,26,.1); }
.table-title,.table-desc { display: block; }.table-title { font-size: 27rpx; font-weight: 700; }.table-desc { margin-top: 8rpx; color:#7C8A8C; font-size:21rpx; }
.scan-table-btn { flex:none; width:calc(100% - 56rpx); min-height:68rpx; margin:-8rpx 28rpx 18rpx; border:1rpx solid rgba(79,111,82,.26); border-radius:18rpx; color:#4F6F52; background:#FFFFFF; font-size:25rpx; font-weight:700; line-height:68rpx; }
.identity-badge { display: flex; align-items: center; gap: 12rpx; }
.badge-icon { width: 56rpx; height: 56rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 22rpx; font-weight: 700; flex: none; }
.member-icon { background: #1a1a1a; color: #b89750; }
.guest-icon { background: #EAF3DE; color: #27500A; }
.badge-info { display: flex; flex-direction: column; align-items: flex-end; }
.badge-tag { font-size: 20rpx; padding: 2rpx 12rpx; border-radius: 16rpx; font-weight: 600; }
.member-tag { background: #1a1a1a; color: #b89750; }
.guest-tag { background: #EAF3DE; color: #27500A; }
.badge-level { font-size: 18rpx; color: #999; margin-top: 4rpx; }
.cart button { color:#fff; background:#8B7355; font-size:23rpx; }
.layout { display:flex; min-height:0; flex:1; overflow:hidden; border-top:1rpx solid rgba(26,26,26,.06); }
.categories { width:156rpx; flex:none; background:rgba(232,228,220,.72); }.category { padding:30rpx 12rpx; border-left:6rpx solid transparent; color:#7C8A8C; text-align:center; font-size:25rpx; }.category.active { border-color:#4F6F52; color:#4F6F52; background:#fff; font-weight:700; }
.goods { height:100%; min-width:0; flex:1; padding:18rpx 18rpx 118rpx; box-sizing:border-box; }.product { display:flex; gap:16rpx; margin-bottom:16rpx; padding:16rpx; }.product-image { width:150rpx; height:150rpx; flex:none; border-radius:16rpx; background:#E8E4DC; }.product-info { display:flex; min-width:0; flex:1; flex-direction:column; }.dish-name,.dish-desc { display:block; }.dish-name { color:#1A1A1A; font-size:27rpx; font-weight:700; }.dish-desc { margin-top:9rpx; color:#7C8A8C; font-size:21rpx; }.product-foot,.counter { display:flex; align-items:center; }.product-foot { justify-content:space-between; margin-top:auto; padding-top:12rpx; gap:12rpx; }.price-block { display:flex; min-width:0; flex-direction:column; gap:5rpx; }.price { color:#8B7355; font-size:30rpx; font-weight:700; }.member-price { color:#4F6F52; font-size:20rpx; font-weight:700; }.counter { gap:12rpx; }.counter view { display:flex; width:43rpx; height:43rpx; align-items:center; justify-content:center; border:1rpx solid #4F6F52; border-radius:50%; color:#4F6F52; }.counter .plus { color:#fff; background:#4F6F52; }.unavailable { color:#A3AAA5; font-size:20rpx; }
.detail-mask { position:fixed; z-index:51; top:0; right:0; bottom:0; left:0; background:rgba(0,0,0,.46); }.detail-dialog { position:fixed; z-index:52; right:0; bottom:0; left:0; display:flex; min-height:720rpx; max-height:82vh; overflow-y:auto; flex-direction:column; padding:28rpx 28rpx calc(152rpx + env(safe-area-inset-bottom)); border-radius:30rpx 30rpx 0 0; background:#fff; box-shadow:0 -12rpx 36rpx rgba(26,26,26,.14); box-sizing:border-box; animation:detail-slide-up .22s ease-out; }.detail-summary { display:flex; gap:22rpx; }.detail-image { display:block; width:246rpx; height:246rpx; flex:none; border-radius:20rpx; background:#E8E4DC; }.detail-body { display:flex; min-width:0; flex:1; flex-direction:column; }.detail-dialog .dish-name { font-size:32rpx; }.detail-dialog .dish-desc { margin-top:6rpx; font-size:25rpx; }.detail-head { display:flex; align-items:flex-start; justify-content:space-between; gap:16rpx; }.detail-head text:last-child { color:#7C8A8C; font-size:44rpx; line-height:32rpx; }.detail-prices { display:flex; align-items:baseline; gap:14rpx; margin-top:18rpx; }.detail-price { color:#8B7355; font-size:44rpx; font-weight:700; }.detail-member-price { color:#4F6F52; font-size:23rpx; font-weight:700; }.detail-counter { display:flex; align-items:center; gap:20rpx; margin-top:18rpx; }.detail-counter view { display:flex; width:58rpx; height:58rpx; align-items:center; justify-content:center; border:1rpx solid #4F6F52; border-radius:50%; color:#4F6F52; font-size:36rpx; line-height:1; }.detail-counter text { min-width:34rpx; color:#1A1A1A; font-size:32rpx; text-align:center; }.detail-counter .plus { color:#fff; background:#4F6F52; }.detail-list { margin-top:26rpx; padding-top:22rpx; border-top:1rpx solid rgba(26,26,26,.08); }.detail-title { display:block; margin-bottom:12rpx; font-size:25rpx; }.detail-row { display:flex; gap:24rpx; padding:9rpx 0; color:#4A554F; font-size:24rpx; }.detail-row text:first-child { min-width:150rpx; }
.people-mask { position:fixed; z-index:55; top:0; right:0; bottom:0; left:0; background:rgba(0,0,0,.42); }
.people-dialog { position:fixed; z-index:56; right:28rpx; bottom:calc(136rpx + env(safe-area-inset-bottom)); left:28rpx; padding:28rpx; border-radius:28rpx; background:#fff; box-shadow:0 18rpx 48rpx rgba(26,26,26,.2); box-sizing:border-box; animation:detail-slide-up .2s ease-out; }
.people-head { display:flex; align-items:center; justify-content:space-between; gap:20rpx; }
.people-head strong { color:#1A1A1A; font-size:34rpx; }
.people-head text { color:#7C8A8C; font-size:44rpx; line-height:1; }
.people-counter { display:flex; align-items:center; justify-content:center; gap:24rpx; margin:34rpx 0; }
.people-counter button { display:flex; width:74rpx; height:74rpx; align-items:center; justify-content:center; border:1rpx solid #4F6F52; border-radius:50%; color:#4F6F52; background:#fff; font-size:42rpx; line-height:1; }
.people-counter input { width:150rpx; height:76rpx; border:1rpx solid rgba(26,26,26,.1); border-radius:16rpx; color:#1A1A1A; background:#F8F6F1; font-size:38rpx; font-weight:700; text-align:center; }
.people-confirm { width:100%; height:78rpx; border-radius:18rpx; color:#fff; background:#4F6F52; font-size:28rpx; font-weight:700; }
.phone-auth-dialog { position:fixed; z-index:56; right:28rpx; bottom:calc(136rpx + env(safe-area-inset-bottom)); left:28rpx; padding:32rpx 28rpx; border-radius:28rpx; background:#fff; box-shadow:0 18rpx 48rpx rgba(26,26,26,.2); box-sizing:border-box; animation:detail-slide-up .2s ease-out; }
.auth-head { display:flex; align-items:center; justify-content:space-between; gap:20rpx; }
.auth-head strong { color:#1a1a1a; font-size:34rpx; }
.auth-head text { color:#7C8A8C; font-size:44rpx; line-height:1; }
.auth-body { margin:24rpx 0; }
.auth-desc { display:block; color:#4A554F; font-size:26rpx; line-height:1.6; }
.auth-note { display:block; margin-top:8rpx; color:#b89750; font-size:22rpx; font-weight:500; }
.auth-phone-btn { width:100%; height:88rpx; margin:0; border-radius:18rpx; color:#b89750; background:#1a1a1a; font-size:28rpx; font-weight:700; line-height:88rpx; letter-spacing:2rpx; }
.auth-skip { margin-top:20rpx; text-align:center; color:#7C8A8C; font-size:24rpx; padding:16rpx 0; }
@keyframes detail-slide-up { from { transform:translateY(100%); } to { transform:translateY(0); } }
.cart { position:fixed; z-index:42; right:24rpx; bottom:calc(136rpx + env(safe-area-inset-bottom)); left:24rpx; display:flex; align-items:center; gap:16rpx; padding:14rpx 17rpx; border-radius:24rpx; color:#fff; background:#22251F; box-shadow:0 16rpx 34rpx rgba(26,26,26,.18); }.bag { position:relative; display:flex; width:66rpx; height:66rpx; align-items:center; justify-content:center; border-radius:50%; background:#4F6F52; }.bag text { position:absolute; top:-8rpx; right:-8rpx; min-width:28rpx; border-radius:18rpx; background:#C9A962; font-size:18rpx; text-align:center; }.cart-copy { display:flex; flex:1; flex-direction:column; }.cart-copy strong { font-size:30rpx; }.cart-copy text { color:rgba(255,255,255,.58); font-size:20rpx; }
.cart-mask { position:fixed; z-index:38; top:0; right:0; bottom:0; left:0; background:rgba(0,0,0,.34); }
.cart-panel { position:fixed; z-index:41; right:24rpx; bottom:calc(224rpx + env(safe-area-inset-bottom)); left:24rpx; max-height:62vh; padding:26rpx 24rpx 18rpx; border-radius:24rpx; background:#fff; box-shadow:0 -12rpx 36rpx rgba(26,26,26,.12); }
.cart-panel-head,.cart-item { display:flex; align-items:center; }.cart-panel-head { justify-content:space-between; padding-bottom:16rpx; border-bottom:1rpx solid rgba(26,26,26,.08); }.cart-panel-head strong { font-size:34rpx; }.cart-panel-head text { color:#4F6F52; font-size:26rpx; }.cart-list { max-height:52vh; }.cart-group { padding-top:18rpx; }.cart-group-title { display:block; color:#4F6F52; font-size:25rpx; font-weight:700; }.cart-item { gap:18rpx; padding:18rpx 0; border-bottom:1rpx solid rgba(26,26,26,.06); }.cart-item-image { width:124rpx; height:124rpx; flex:none; border-radius:16rpx; background:#E8E4DC; }.cart-item-copy { min-width:0; flex:1; }.cart-item-copy strong,.cart-item-copy text { display:block; }.cart-item-copy strong { overflow:hidden; font-size:29rpx; text-overflow:ellipsis; white-space:nowrap; }.cart-item-copy text { margin-top:10rpx; color:#8B7355; font-size:29rpx; font-weight:700; }.cart-item-copy .cart-member-price { margin-top:5rpx; color:#4F6F52; font-size:21rpx; }.cart-item .counter { flex:none; gap:14rpx; }.cart-item .counter view { width:52rpx; height:52rpx; font-size:30rpx; }.cart-item .counter text { min-width:24rpx; font-size:27rpx; text-align:center; }
