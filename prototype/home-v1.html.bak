<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>停云山居 - 首页</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'ink-black': '#1a1a1a',
            'ink-gray': '#4a4a4a',
            'mountain-green': '#4F6F52',
            'mist-gray': '#7C8A8C',
            'paper-white': '#F8F6F1',
            'warm-beige': '#E8E4DC',
            'accent-gold': '#C9A962',
          },
          fontFamily: {
            'serif': ['Noto Serif SC', 'serif'],
          },
        }
      }
    }
  </script>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Noto Serif SC', serif;
      background: #F8F6F1;
      color: #1a1a1a;
      overflow-x: hidden;
    }
    
    /* 山水画背景 */
    .landscape-bg {
      background: 
        radial-gradient(ellipse at 30% 20%, rgba(79, 111, 82, 0.15) 0%, transparent 60%),
        radial-gradient(ellipse at 70% 60%, rgba(124, 138, 140, 0.1) 0%, transparent 50%),
        linear-gradient(180deg, #F8F6F1 0%, #F0EDE6 100%);
      min-height: 100vh;
    }
    
    /* 开屏动画 */
    .splash-screen {
      position: fixed;
      inset: 0;
      background: linear-gradient(135deg, #4F6F52 0%, #2d4a30 100%);
      z-index: 1000;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      animation: fadeOut 0.8s ease-in-out 2.5s forwards;
    }
    
    @keyframes fadeOut {
      to {
        opacity: 0;
        visibility: hidden;
      }
    }
    
    .splash-logo {
      width: 100px;
      height: 100px;
      background: rgba(255,255,255,0.15);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 48px;
      border: 2px solid rgba(201, 169, 98, 0.5);
      animation: scaleIn 0.8s ease-out;
    }
    
    @keyframes scaleIn {
      from {
        transform: scale(0.5);
        opacity: 0;
      }
      to {
        transform: scale(1);
        opacity: 1;
      }
    }
    
    .splash-text {
      margin-top: 24px;
      color: white;
      font-size: 20px;
      letter-spacing: 8px;
      animation: slideUp 0.8s ease-out 0.3s both;
    }
    
    @keyframes slideUp {
      from {
        transform: translateY(20px);
        opacity: 0;
      }
      to {
        transform: translateY(0);
        opacity: 1;
      }
    }
    
    .splash-subtext {
      margin-top: 12px;
      color: rgba(255,255,255,0.7);
      font-size: 14px;
      letter-spacing: 4px;
      animation: slideUp 0.8s ease-out 0.5s both;
    }
    
    /* 轮播图 */
    .carousel-container {
      position: relative;
      height: 220px;
      overflow: hidden;
    }
    
    .carousel-slide {
      position: absolute;
      width: 100%;
      height: 100%;
      opacity: 0;
      transition: opacity 0.8s ease-in-out;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    
    .carousel-slide.active {
      opacity: 1;
    }
    
    .carousel-slide .bg-image {
      position: absolute;
      inset: 0;
      background-size: cover;
      background-position: center;
      filter: brightness(0.85);
    }
    
    .carousel-slide .overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.3) 100%);
    }
    
    .carousel-content {
      position: relative;
      z-index: 10;
      text-align: center;
      color: white;
    }
    
    .carousel-dots {
      position: absolute;
      bottom: 16px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 8px;
      z-index: 20;
    }
    
    .dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: rgba(255,255,255,0.4);
      transition: all 0.3s;
    }
    
    .dot.active {
      width: 20px;
      border-radius: 3px;
      background: white;
    }
    
    /* 卡片样式 */
    .card {
      background: white;
      border-radius: 16px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.04);
      overflow: hidden;
    }
    
    /* 点单入口 */
    .order-entry {
      background: linear-gradient(135deg, #4F6F52 0%, #3d5a40 100%);
      border-radius: 20px;
      padding: 24px;
      color: white;
      position: relative;
      overflow: hidden;
    }
    
    .order-entry::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -20%;
      width: 200px;
      height: 200px;
      background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
      border-radius: 50%;
    }
    
    /* 预订入口 */
    .booking-entry {
      background: linear-gradient(135deg, #8B7355 0%, #6B5940 100%);
      border-radius: 20px;
      padding: 24px;
      color: white;
      position: relative;
      overflow: hidden;
      cursor: pointer;
    }
    
    .booking-entry::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -20%;
      width: 200px;
      height: 200px;
      background: radial-gradient(circle, rgba(201, 169, 98, 0.15) 0%, transparent 70%);
      border-radius: 50%;
    }
    
    .entry-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    
    .entry-grid .order-entry,
    .entry-grid .booking-entry {
      padding: 20px 16px;
      min-height: 120px;
      display: flex;
      align-items: center;
    }
    
    /* 活动卡片 */
    .activity-card {
      background: white;
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid rgba(0,0,0,0.04);
    }
    
    .activity-image {
      height: 100px;
      background: linear-gradient(135deg, #E8E4DC 0%, #d4cfc4 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 40px;
    }
    
    /* 山居介绍 */
    .intro-section {
      background: linear-gradient(180deg, #F8F6F1 0%, #E8E4DC 100%);
      border-radius: 20px 20px 0 0;
      position: relative;
    }
    
    .intro-section::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 60px;
      background: linear-gradient(to bottom, rgba(248,246,241,0) 0%, #F8F6F1 100%);
    }
    
    /* 装饰线 */
    .decorative-line {
      width: 40px;
      height: 2px;
      background: #C9A962;
    }
    
    /* 底部导航 */
    .bottom-nav {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: white;
      border-top: 1px solid rgba(0,0,0,0.06);
      padding: 8px 0 24px;
      display: flex;
      justify-content: space-around;
      z-index: 100;
    }
    
    .nav-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      padding: 4px 16px;
      color: #7C8A8C;
      transition: color 0.3s;
    }
    
    .nav-item.active {
      color: #4F6F52;
    }
    
    .nav-icon {
      width: 24px;
      height: 24px;
    }
    
    /* 滚动容器 */
    .scroll-container {
      height: calc(100vh - 76px);
      overflow-y: auto;
      padding-bottom: 100px;
    }
    
    .scroll-container::-webkit-scrollbar {
      display: none;
    }
    
    /* 了解详情按钮 */
    .detail-btn {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 8px 16px;
      background: #4F6F52;
      color: white;
      border-radius: 20px;
      font-size: 12px;
      letter-spacing: 1px;
      margin-top: 12px;
    }
  </style>
</head>
<body>
  <!-- 开屏动画 -->
  <div class="splash-screen" id="splash">
    <div class="splash-logo">⛰️</div>
    <div class="splash-text">停云山居</div>
    <div class="splash-subtext">山里请云上坐</div>
  </div>
  
  <div class="landscape-bg">
    <div class="scroll-container">
      <!-- 轮播图 -->
      <div class="carousel-container">
        <div class="carousel-slide active">
          <div class="bg-image" style="background-image: linear-gradient(135deg, #4F6F52 0%, #2d4a30 100%);"></div>
          <div class="overlay"></div>
          <div class="carousel-content">
            <p class="text-sm tracking-widest mb-2 opacity-80">静心禅居</p>
            <h2 class="text-2xl font-bold tracking-wider">停云山居</h2>
            <div class="w-12 h-0.5 bg-white/60 mx-auto mt-3"></div>
          </div>
        </div>
        <div class="carousel-slide">
          <div class="bg-image" style="background-image: linear-gradient(135deg, #7C8A8C 0%, #5a686a 100%);"></div>
          <div class="overlay"></div>
          <div class="carousel-content">
            <p class="text-sm tracking-widest mb-2 opacity-80">品味素斋</p>
            <h2 class="text-2xl font-bold tracking-wider">禅意美食</h2>
            <div class="w-12 h-0.5 bg-white/60 mx-auto mt-3"></div>
          </div>
        </div>
        <div class="carousel-slide">
          <div class="bg-image" style="background-image: linear-gradient(135deg, #C9A962 0%, #a08040 100%);"></div>
          <div class="overlay"></div>
          <div class="carousel-content">
            <p class="text-sm tracking-widest mb-2 opacity-80">山间雅集</p>
            <h2 class="text-2xl font-bold tracking-wider">文化活动</h2>
            <div class="w-12 h-0.5 bg-white/60 mx-auto mt-3"></div>
          </div>
        </div>
        <div class="carousel-dots">
          <div class="dot active"></div>
          <div class="dot"></div>
          <div class="dot"></div>
        </div>
      </div>
      
      <!-- 快捷入口 -->
      <div class="px-4 -mt-6 relative z-10">
        <div class="entry-grid">
          <div class="order-entry" onclick="navigateTo('menu')">
            <div>
              <p class="text-white/70 text-xs tracking-wider mb-1">扫码点餐</p>
              <h3 class="text-lg font-bold tracking-wide">开始点餐</h3>
              <p class="text-white/60 text-xs mt-2 tracking-wider">素斋 · 团餐 · 茶点</p>
            </div>
          </div>
          <div class="booking-entry" onclick="navigateToBooking()">
            <div>
              <p class="text-white/70 text-xs tracking-wider mb-1">提前预约</p>
              <h3 class="text-lg font-bold tracking-wide">预约预订</h3>
              <p class="text-white/60 text-xs mt-2 tracking-wider">住宿 · 用餐 · 空间</p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- 山居介绍 -->
      <div class="px-4 mt-6">
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3">
            <div class="decorative-line"></div>
            <h3 class="text-lg font-bold text-ink-black tracking-wider">山居介绍</h3>
          </div>
        </div>
        
        <div class="bg-white rounded-2xl p-5 shadow-sm">
          <div class="h-32 bg-gradient-to-br from-mountain-green/20 to-mist-gray/20 rounded-xl flex items-center justify-center mb-4">
            <span class="text-5xl">🏔️</span>
          </div>
          
          <h4 class="font-bold text-ink-black text-base tracking-wide mb-3">停云山居</h4>
          
          <p class="text-sm text-ink-gray leading-relaxed tracking-wide">
            停云山居坐落于青山绿水之间，是一处集禅修、茶艺、美食、住宿于一体的文化空间。在这里，您可以远离城市喧嚣，静心感受自然之美。
          </p>
          
          <div class="flex flex-wrap gap-2 mt-4">
            <span class="px-3 py-1.5 bg-mountain-green/10 text-mountain-green text-xs rounded-full tracking-wider">禅修体验</span>
            <span class="px-3 py-1.5 bg-mountain-green/10 text-mountain-green text-xs rounded-full tracking-wider">茶艺品鉴</span>
            <span class="px-3 py-1.5 bg-mountain-green/10 text-mountain-green text-xs rounded-full tracking-wider">精品素斋</span>
            <span class="px-3 py-1.5 bg-mountain-green/10 text-mountain-green text-xs rounded-full tracking-wider">宁静住宿</span>
          </div>
          
          <button class="detail-btn" onclick="showDetail()">
            了解详情
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </button>
        </div>
      </div>
      
      <!-- 最近活动 -->
      <div class="px-4 mt-6">
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3">
            <div class="decorative-line"></div>
            <h3 class="text-lg font-bold text-ink-black tracking-wider">最近活动</h3>
          </div>
          <span class="text-xs text-mist-gray tracking-wider">查看更多</span>
        </div>
        
        <div class="space-y-3">
          <div class="activity-card">
            <div class="activity-image">🍵</div>
            <div class="p-3">
              <h4 class="font-medium text-ink-black text-sm tracking-wide">茶艺品鉴会</h4>
              <p class="text-xs text-mist-gray mt-1">12月15日 · 下午14:00</p>
            </div>
          </div>
          
          <div class="activity-card">
            <div class="activity-image" style="background: linear-gradient(135deg, #d4cfc4 0%, #c0bbb0 100%);">🧘</div>
            <div class="p-3">
              <h4 class="font-medium text-ink-black text-sm tracking-wide">禅修冥想体验</h4>
              <p class="text-xs text-mist-gray mt-1">12月18日 · 上午09:00</p>
            </div>
          </div>
          
          <div class="activity-card">
            <div class="activity-image" style="background: linear-gradient(135deg, #c9c4b8 0%, #b5b0a4 100%);">🎋</div>
            <div class="p-3">
              <h4 class="font-medium text-ink-black text-sm tracking-wide">书法雅集</h4>
              <p class="text-xs text-mist-gray mt-1">12月22日 · 下午14:00</p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- 底部留白 -->
      <div class="h-8"></div>
    </div>
    
    <!-- 底部导航 -->
    <div class="bottom-nav">
      <div class="nav-item active">
        <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
        <span class="text-xs tracking-wider">首页</span>
      </div>
      <div class="nav-item" onclick="navigateTo('menu')">
        <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        <span class="text-xs tracking-wider">点单</span>
      </div>
      <div class="nav-item" onclick="navigateTo('orders')">
        <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
        </svg>
        <span class="text-xs tracking-wider">订单</span>
      </div>
      <div class="nav-item" onclick="navigateTo('profile')">
        <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        <span class="text-xs tracking-wider">我的</span>
      </div>
    </div>
  </div>

  <script>
    // 开屏动画结束后隐藏
    setTimeout(() => {
      const splash = document.getElementById('splash');
      if (splash) {
        splash.style.display = 'none';
      }
    }, 3500);
    
    // 轮播图
    let currentSlide = 0;
    const slides = document.querySelectorAll('.carousel-slide');
    const dots = document.querySelectorAll('.dot');
    
    function showSlide(index) {
      slides.forEach((slide, i) => {
        slide.classList.toggle('active', i === index);
      });
      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === index);
      });
    }
    
    function nextSlide() {
      currentSlide = (currentSlide + 1) % slides.length;
      showSlide(currentSlide);
    }
    
    setInterval(nextSlide, 4000);
    
    // 页面跳转
    function navigateTo(page) {
      if (window.parent && window.parent !== window) {
        window.parent.postMessage({
          type: 'navigate',
          target: page,
          page: page + '.html'
        }, '*');
      }
    }
    
    // 预约预订
    function navigateToBooking() {
      if (window.parent && window.parent !== window) {
        window.parent.postMessage({
          type: 'navigate',
          target: 'booking',
          page: 'booking.html'
        }, '*');
      }
    }
    
    // 了解详情
    function showDetail() {
      alert('山居详情页面');
    }
  </script>
</body>
</html>
